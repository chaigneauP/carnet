POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=game_library
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Utilisée par Prisma / le backend lorsqu'il tourne dans Docker.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/game_library?schema=public

# Variante pratique si les commandes Prisma sont lancées depuis l'hôte.
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5432/game_library?schema=public

