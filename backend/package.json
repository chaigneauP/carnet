{
  "name": "carnet-backend",
  "version": "0.1.0",
  "private": true,
  "description": "REST API backend for the carnet project",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "db:seed": "tsx src/scripts/run-sql-seed.ts",
    "check": "npm run build",
    "test": "jest --runInBand",
    "test:e2e": "jest --runInBand --testPathPattern=test/app.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.16",
    "@nestjs/core": "11.1.16",
    "@nestjs/platform-express": "11.1.16",
    "@nestjs/typeorm": "11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.4.7",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "0.3.28"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.16",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
