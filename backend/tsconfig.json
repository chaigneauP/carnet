{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "jest"],
    "sourceMap": true
  },
  "include": [
    "src/main.ts",
    "src/app.controller.ts",
    "src/app.module.ts",
    "src/common/**/*.ts",
    "src/database/**/*.ts",
    "src/games/**/*.ts",
    "src/health/**/*.ts",
    "src/scripts/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
